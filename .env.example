# keiba-ev — 環境変数テンプレ
#
# 使い方:
#   cp .env.example .env
#   # 取得した API キーを書き込む (.env は .gitignore 済み)
#
# .env は src/analyze.py が起動時に python-dotenv で読み込み、
# subprocess で spawn する claude CLI に継承されます。
# claude は cwd の .mcp.json を読み、Brave / Tavily サーバ起動時に
# ${BRAVE_API_KEY} / ${TAVILY_API_KEY} を展開します。

# Brave Search API
# 取得: https://api.search.brave.com/app/keys
BRAVE_API_KEY=BSAxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tavily Search API
# 取得: https://app.tavily.com/home
TAVILY_API_KEY=tvly-dev-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API (LLM 評価で claude CLI が必要とする標準名)
# 取得: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (任意) FastAPI に X-API-Key 認証を付ける場合
# API_SHARED_KEY=
